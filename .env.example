# =============================================================================
# Microsistemas - Configuracion de entorno
# =============================================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Cambia DB_PASS por una contrasena propia (nunca uses el valor de ejemplo)
#   3. El archivo .env esta en .gitignore -- nunca lo subas al repositorio
# =============================================================================

# --- Base de datos -----------------------------------------------------------

DB_DRIVER=mysql

# Para XAMPP local: usa 'localhost'
# Para Docker Compose: usa 'db' (nombre del servicio)
DB_HOST=localhost

# Usuario de base de datos.
# RECOMENDACION: crea un usuario especifico con permisos minimos (SELECT, INSERT, UPDATE)
# en lugar de usar root. Root solo para desarrollo inicial.
DB_USER=root

# Contrasena de base de datos.
# OBLIGATORIO para Docker: el contenedor falla si esta variable no esta definida.
# Cambia este valor por uno propio antes de levantar.
# NUNCA uses esta contrasena en produccion ni en un servidor accesible desde Internet.
DB_PASS=dev_local_only

# Nombre de la base de datos
DB_NAME=portal_portafolio

# --- Usuario de aplicacion (opcional, menor privilegio) ----------------------
# Si se definen, el script docker/init-db.sh crea este usuario con permisos
# minimos (SELECT/INSERT/UPDATE/DELETE) en la BD. Recomendado para produccion.
# Dejar en blanco para usar root (solo desarrollo local).
DB_APP_USER=
DB_APP_PASS=

# --- SqlViewer ----------------------------------------------------------------
# Modo solo lectura: bloquea INSERT/UPDATE/DELETE/DROP/ALTER/TRUNCATE en el visor.
# Desactivar (false) solo en entorno local controlado si se necesita escritura.
SQLVIEWER_READONLY=true

# =============================================================================
# ADVERTENCIA DE SEGURIDAD
# =============================================================================
# Este stack esta disenado EXCLUSIVAMENTE para uso local o en redes controladas.
# NO expongas Docker ni XAMPP directamente a Internet sin:
#   - HTTPS (certificado SSL)
#   - Proxy inverso (Nginx/Traefik) con autenticacion
#   - Firewall que restrinja acceso a los puertos 8080 y 3306
# Ver: SECURITY.md para el modelo de amenaza completo.
# =============================================================================
