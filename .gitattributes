# Normalizacion universal de fin de linea
* text=auto

# Shell scripts MUST use LF -- CRLF breaks bash inside Linux containers
*.sh text eol=lf

# Archivos y directorios que no deberían incluirse en los .zip Release (export-ignore)
/.github/           export-ignore
/.gitignore         export-ignore
/.gitattributes     export-ignore
/.editorconfig      export-ignore
/.php-cs-fixer*     export-ignore
/.markdownlint.json export-ignore
/tests/             export-ignore
/test/              export-ignore
/Makefile           export-ignore

# Excluir dependencias obvias si se generasen localmente
/vendor/            export-ignore
/node_modules/      export-ignore
